#lines(x=grasclim$ppt_tot_scaled, y=flow_endo1_median_posy, col="cornflowerblue", lty=1, type="l")
invlogit<-function(x){exp(x)/(1+exp(x))}
lines(x=ppt_tot_dummy, y=invlogit(flow_endo1_median_posy), col="cornflowerblue")
lines(x=ppt_tot_dummy, y=invlogit(flow_endo0_median_posy), col="deeppink1")
#plot(x=grasclim$ppt_tot_scaled, y=flow_endo0_median_posy, col="deeppink1", lty=1, type="l")
#lines(x=grasclim$ppt_tot_scaled, y=flow_endo1_median_posy, col="cornflowerblue", lty=1, type="l")
invlogit<-function(x){exp(x)/(1+exp(x))}
plot(x=grasclim$ppt_tot_scaled, y=grasclim$flw_count_t>0, col="purple")
lines(x=ppt_tot_dummy, y=invlogit(flow_endo1_median_posy), col="cornflowerblue")
lines(x=ppt_tot_dummy, y=invlogit(flow_endo0_median_posy), col="deeppink1")
unique(grasclim$ppt_tot_scaled)
plot(x=grasclim$ppt_tot_scaled[grasclim$species=="POSY"],
y=grasclim$flw_count_t[grasclim$species=="POSY"]>0, col="purple")
lines(x=ppt_tot_dummy, y=invlogit(flow_endo1_median_posy), col="cornflowerblue")
lines(x=ppt_tot_dummy, y=invlogit(flow_endo0_median_posy), col="deeppink1")
