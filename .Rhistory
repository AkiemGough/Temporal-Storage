"FESU" = "tomato",
"LOAR" = "deeppink",
"POAL" = "purple",
"POAU" = "slateblue",
"POSY" = "cornflowerblue")) +
labs(x = "months prior",
y = "weight",
title = "Comparison of Weights of Precipitation in Each Time Scale")
